NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret

# App code reads DATABASE_URL (Prisma + native driver). Use your Mongo connection string here.
DATABASE_URL=mongodb+srv://username:password@cluster-url/db-name?retryWrites=true&w=majority

# Optional alias for docs only — if you use this name, copy the same value to DATABASE_URL.
# MONGODB_URI=mongodb+srv://username:password@cluster-url/db-name

PUSHER_APP_ID=app-id
PUSHER_KEY=public-key
PUSHER_SECRET=secret-key
PUSHER_CLUSTER=ap3

CLOUDINARY_CLOUD_NAME=cloud-name
CLOUDINARY_API_KEY=api-key
CLOUDINARY_API_SECRET=api-secret

# REG_KEY=optional-invite-key
